#
# Skill Matrix backend (.NET) local configuration example
#

# MySQL connection used by SkillMatrixDbContext / migration runner
SKILLMATRIX__MYSQL__CONNECTIONSTRING=Server=localhost;Port=3306;Database=skill_matrix;User=root;Password=skillmatrix_root;

# Evidence file storage (local dev)
SKILLMATRIX__FILES__EVIDENCEBASEPATH=.\.local-data\evidence

# Auth (optional; if unset in Development, a local dev auth handler can be used)
AUTH__JWT__AUTHORITY=
AUTH__JWT__AUDIENCE=itp

